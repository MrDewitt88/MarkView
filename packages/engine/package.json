{
  "name": "@teammind/markview-engine",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./pdf": {
      "import": {
        "types": "./dist/pdf.d.ts",
        "default": "./dist/pdf.js"
      },
      "require": {
        "types": "./dist/pdf.d.cts",
        "default": "./dist/pdf.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "linkedom": "^0.16.0",
    "mermaid": "^11.4.0",
    "node-forge": "^1.3.3",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "shiki": "^1.26.0",
    "unified": "^11.0.5"
  },
  "peerDependencies": {
    "playwright": "^1.49.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "@types/node": "^22.0.0",
    "@types/node-forge": "^1.3.14",
    "playwright": "^1.49.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
